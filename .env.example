# Local dev (docker-compose). Point at Neon/Supabase etc. by swapping this string.
DATABASE_URL=postgres://groundwork:groundwork@localhost:5433/groundwork
# Append-only raw capture store (record/replay)
RAW_STORE_DIR=./raw_store
# Optional: https://api.census.gov/data/key_signup.html (raises rate limits)
CENSUS_API_KEY=
# API bind address
API_ADDR=127.0.0.1:8080
